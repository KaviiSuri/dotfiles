theme = dark:TokyoNight Night,light:TokyoNight Day
background-opacity = 0.8
background-blur = 10
window-decoration = none
font-size = 16
font-family = FiraCodeNerdFontMono

# tmux is the control plane; Ghostty should stay out of split navigation.
macos-option-as-alt = left
shell-integration = detect
shell-integration-features = cursor,sudo,ssh-terminfo,ssh-env
clipboard-read = ask
clipboard-write = allow
mouse-shift-capture = never
cursor-click-to-move = true
notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
background-opacity-cells = true
